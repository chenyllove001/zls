.class-header {
  margin-bottom: 16rpx;
}

.class-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.class-code {
  font-size: 26rpx;
  color: #ff69b4;
  background: #ffe8f0;
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.member-count {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.divider {
  text-align: center;
  margin: 30rpx 0;
  color: #999;
  position: relative;
}

.divider::before,
.divider::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 40%;
  height: 1rpx;
  background: #eee;
}

.divider::before {
  left: 0;
}

.divider::after {
  right: 0;
}

.empty-state {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

.leaderboard {
  margin-top: 10rpx;
}

/* 验证弹窗 */
.verification-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.verification-card {
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.verification-hint {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.question-card {
  background: #fff8fa;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  border: 4rpx dashed #ff9a9e;
}

.question {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff69b4;
}

.error-text {
  color: #ff4d4f;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.button-group {
  display: flex;
  gap: 20rpx;
}

.button-group button {
  flex: 1;
}

/* 班级列表 */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.class-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #fff8fa;
  border-radius: 20rpx;
  border: 3rpx solid #ffe8f0;
}

.class-item-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.class-item-count {
  font-size: 24rpx;
  color: #999;
}

.join-btn {
  background: linear-gradient(135deg, #ff9a9e 0%, #ffb3c1 100%);
  color: #fff;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}
