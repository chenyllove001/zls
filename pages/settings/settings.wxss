/* 自定义任务列表 */
.task-list-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.task-list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.task-count {
  font-size: 24rpx;
  color: #999;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  position: relative;
}

.tab-item.active {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #fff;
  font-weight: 500;
}

.tab-hover {
  opacity: 0.7;
}

.tab-badge {
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 6rpx;
  margin-left: 8rpx;
}

.tab-content {
  min-height: 200rpx;
}

.empty-tasks {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.task-info {
  flex: 1;
  margin-right: 20rpx;
}

.task-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.task-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-exp {
  font-size: 22rpx;
  color: #52c41a;
  background: #f6ffed;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.task-creator {
  font-size: 22rpx;
  color: #999;
}

.task-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  flex-shrink: 0;
  white-space: nowrap;
  position: relative;
  z-index: 10;
}

.btn-edit {
  background: #52c41a !important;
  color: #ffffff !important;
  border-radius: 30rpx !important;
  font-size: 26rpx !important;
  line-height: 60rpx !important;
  padding: 0 24rpx !important;
  border: none !important;
  width: auto !important;
  display: inline-block !important;
  margin: 0 !important;
  margin-right: 12rpx !important;
}

.btn-edit::after {
  border: none !important;
}

.btn-delete {
  background: #ff4d4f !important;
  color: #ffffff !important;
  border-radius: 30rpx !important;
  font-size: 26rpx !important;
  line-height: 60rpx !important;
  padding: 0 24rpx !important;
  border: none !important;
  width: auto !important;
  display: inline-block !important;
  margin: 0 !important;
}

.btn-delete::after {
  border: none !important;
}

.task-disabled {
  font-size: 24rpx;
  color: #ccc;
}
