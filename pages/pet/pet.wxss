.pet-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.pet-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 32rpx;
  background: linear-gradient(135deg, #ffe8f0 0%, #fff0f5 100%);
  border: 6rpx solid #ffd6e3;
}

.pet-image {
  width: 100%;
  height: 100%;
}

.pet-basic {
  flex: 1;
}

.pet-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.pet-level {
  font-size: 28rpx;
  color: #ff69b4;
  background: #ffe8f0;
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.attribute-points {
  font-size: 26rpx;
  color: #ffb800;
  background: #fff8e1;
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.stat-item {
  margin-bottom: 32rpx;
}

.stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 30rpx;
  color: #333;
}

.stat-value {
  font-size: 26rpx;
  color: #999;
}

.attributes-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.attr-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff8fa;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  border: 3rpx solid #ffe8f0;
}

.attr-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.attr-icon {
  font-size: 40rpx;
}

.attr-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.attr-value {
  font-size: 32rpx;
  color: #ff69b4;
  font-weight: bold;
  margin-left: 12rpx;
}

.btn-add {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #ff9a9e 0%, #ffb3c1 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 60rpx;
}

.btn-add::after {
  border: none;
}

.evolution-info {
  background: #fef5ff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.evolution-info text {
  font-size: 26rpx;
  color: #666;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 32rpx;
}

.adopt-time {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}
