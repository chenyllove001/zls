.pet-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.pet-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  margin-right: 24rpx;
  background: #f0f0f0;
}

.pet-avatar-image {
  width: 100%;
  height: 100%;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.pet-stats {
  width: 100%;
}

.stat-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.stat-label {
  width: 100rpx;
  font-size: 24rpx;
  color: #666;
}

.stat-item .progress-bar {
  flex: 1;
  height: 12rpx;
}
